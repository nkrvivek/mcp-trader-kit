# traderkit — environment variables
# Copy to `.env` and fill in real values. `.env` is git-ignored.

# ---- SnapTrade read MCP (market-data + positions + activities) -------------
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_USER_SECRET=
SNAPTRADE_USER_ID=
SNAPTRADE_CLIENT_ID=

# How traderkit spawns the snaptrade-read server (for wash-sale lookups).
# Leave blank to disable — wash-sale check will short-circuit as "unavailable".
SNAPTRADE_READ_COMMAND=
SNAPTRADE_READ_ARGS=

# ---- Trade-guard hook ------------------------------------------------------
# Required for v0.1.1+: explicit command to launch traderkit.
# Example: /usr/local/bin/node /abs/path/to/mcp-servers/trade-guard/dist/index.js
TRADERKIT_GUARD_COMMAND=
TRADERKIT_GUARD_ARGS=

# Kit root. Defaults to $HOME/.traderkit.
TRADERKIT_ROOT=

# Fail-open the hook (NOT recommended). Default fails closed on any error.
# TRADERKIT_FAIL_OPEN=true

# ---- Live-trade smoke script ----------------------------------------------
TRADERKIT_ALLOW_LIVE=false
SMOKE_ACCOUNT_ID=
SMOKE_PROFILE=

# ---- Optional analysis integrations ---------------------------------------
ANTHROPIC_API_KEY=
EXA_API_KEY=
UW_TOKEN=
