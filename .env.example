# traderkit — environment variables
# Copy to `.env` and fill in real values. `.env` is git-ignored.

# ---- SnapTrade read MCP (market-data + positions + activities) -------------
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_USER_SECRET=
SNAPTRADE_USER_ID=
SNAPTRADE_CLIENT_ID=

# How traderkit spawns the snaptrade-read server (for wash-sale lookups).
# Leave blank to disable — wash-sale check will short-circuit as "unavailable".
SNAPTRADE_READ_COMMAND=
SNAPTRADE_READ_ARGS=

# ---- Trade-guard hook ------------------------------------------------------
# Required for v0.1.1+: explicit command to launch traderkit.
# Example: /usr/local/bin/node /abs/path/to/mcp-servers/traderkit/dist/index.js
TRADERKIT_GUARD_COMMAND=
TRADERKIT_GUARD_ARGS=

# Kit root. Defaults to $HOME/.traderkit.
TRADERKIT_ROOT=

# Fail-open the hook (NOT recommended). Default fails closed on any error.
# TRADERKIT_FAIL_OPEN=true

# ---- Live-trade smoke script ----------------------------------------------
TRADERKIT_ALLOW_LIVE=false
SMOKE_ACCOUNT_ID=
SMOKE_PROFILE=

# ---- Optional analysis integrations ---------------------------------------
# Reserved for future use; not consumed by traderkit runtime.
ANTHROPIC_API_KEY=
EXA_API_KEY=
# Unusual Whales — required by screen_options + calc_roll.
UW_TOKEN=
# Override the UW API base URL (defaults to https://api.unusualwhales.com/api).
# UW_BASE=
# Finnhub — free tier sufficient. https://finnhub.io/dashboard/api
# Required by screen_options tool (mkt cap, sector). FMP preferred for earnings.
FINNHUB_API_KEY=
# Override the Finnhub API base URL (defaults to https://finnhub.io/api/v1).
# FINNHUB_BASE=
# Financial Modeling Prep — authoritative earnings dates, DCF, analyst target.
# /stable/ endpoints only on free tier (250/day). Used by screen_options +
# fmp_fundamentals tools.
FMP_API_KEY=
# FMP_BASE=https://financialmodelingprep.com/stable
